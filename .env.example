# OpenHands SDK Playground
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# LLM API Keys (Required - set at least one)
# =============================================================================

# Primary LLM API key (used by default)
LLM_API_KEY=your-api-key-here

# Provider-specific keys (optional, for multi-provider setups)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# =============================================================================
# LLM Configuration (Optional)
# =============================================================================

# Override the default model (set in config/settings.yaml)
# LLM_MODEL=anthropic/claude-sonnet-4-5-20250929

# Custom LLM base URL (for proxies or self-hosted models)
# LLM_BASE_URL=https://api.example.com/v1

# =============================================================================
# Runtime Configuration (Optional)
# =============================================================================

# Working directory for agent operations
# LAB_WORKING_DIR=/path/to/workspace

# Runtime environment: "local" or "docker"
# LAB_RUNTIME=local

# Docker image (when using docker runtime)
# LAB_DOCKER_IMAGE=python:3.12-slim

# =============================================================================
# UI Configuration (Optional)
# =============================================================================

# Suppress the OpenHands SDK banner
# OPENHANDS_SUPPRESS_BANNER=1

# Streamlit server settings
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true

# =============================================================================
# Development & Debugging (Optional)
# =============================================================================

# Enable debug logging
# LAB_DEBUG=1

# Log level: DEBUG, INFO, WARNING, ERROR
# LAB_LOG_LEVEL=INFO
